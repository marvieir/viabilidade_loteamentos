# Dados pesados gerados por pipeline (NÃO vão no git — ficam em volume; ARCHITECTURE §4).
# A malha geométrica do IBGE é grande (~dezenas de MB). A LISTA LEVE
# (lista_municipios.json, ~150 KB) É versionada — por isso não entra aqui.
backend/app/perfis/malha_ibge.geojson
# Rasters de vegetação (Fase 2.2) — recortes baixados por pipeline, ficam em volume.
backend/app/perfis/*.tif
backend/app/perfis/verde.tif
# Perfis municipais confirmados da LUOS (Fase 1.8) — dado do operador, persistido em volume.
backend/app/perfis/municipais/
# Fichas jurídicas confirmadas por análise (Fase 3) — dado do operador, persistido em volume.
backend/app/perfis/juridico/
# Premissas/execução financeira por análise (Fase 4) — dado do operador, persistido em volume.
backend/app/perfis/financeira/
# Avaliação econômica por análise (Fase 5) — dado do operador, persistido em volume.
backend/app/perfis/economica/
# Estudos de massa (Fase 9) — snapshots versionados por análise, persistidos em volume.
backend/app/perfis/urbanismo/

# .env do backend (segredos/caminhos da máquina) — versionamos só o .env.example.
backend/.env

# CA corporativa para TLS sob inspeção (Fase 1.8) — segredo da máquina, fora do git.
backend/certs/
# Premissas/execução financeira por análise (Fase 4) — também cobre 4.1/4.2.

# Fase 12 — banco de dev/teste (SQLite local). Produção usa Postgres em volume.
backend/dev.db
backend/*.db

# Dados de custo/uso + perfis do operador (dev bind mount)
backend/app/perfis/_dados/
