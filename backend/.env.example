# Backend (DEV LOCAL) — variáveis de ambiente.
# Uso:
#   cp .env.example .env
#   uvicorn app.main:app --reload --port 8700 --env-file .env
#
# No Docker/compose estas variáveis vêm do docker-compose.yml (caminhos /data/...),
# NÃO deste arquivo. Os caminhos abaixo são relativos a backend/ (rode o uvicorn daqui).

# Origens liberadas no CORS (frontend)
CORS_ORIGINS=http://localhost:3700

# Fase 1.7 — malha IBGE p/ detecção automática de município.
# Gere com:  python -m scripts.baixar_malha_ibge --saida app/perfis/malha_ibge.geojson
MALHA_IBGE_PATH=app/perfis/malha_ibge.geojson

# Fase 2.1 — aquisição ambiental real (SIGMINE/ANA/ICMBio/ANEEL)
AMBIENTAL_FONTE_REAL=1

# Fase 2.2 — área verde (ESA WorldCover 10m, sem login).
# PADRÃO = modo AUTOMÁTICO: lê o COG público por HTTP e escolhe o tile pela posição da
# gleba — funciona para QUALQUER KMZ sem recorte manual. Requer egress ao bucket público.
VEGETACAO_WORLDCOVER_AUTO=1
# Offline/override (sem egress): desligue o auto e aponte um recorte por gleba, gerado com
#   python -m scripts.baixar_worldcover --kmz SUA_GLEBA.kmz --saida app/perfis/verde.tif
# VEGETACAO_WORLDCOVER_AUTO=0
# VEGETACAO_RASTER_PATH=app/perfis/verde.tif
# Opcional — classes que contam como verde (default WorldCover: 10 árvores, 20 arbustiva,
# 90 área úmida, 95 mangue). Inclua 30 p/ contar pastagem/campo.
# VEGETACAO_CLASSES_VERDE=10,20,90,95

# Fase 2.5 — declividade via DEM (Copernicus GLO-30 Public, SEM chave).
# PADRÃO keyless: COG público por HTTP, tile pela posição da gleba (qualquer KMZ).
DEM_FONTE=copernicus_auto
# Desligar (sem egress): DEM_FONTE=none. Fallback offline: aponte um DEM local:
# DEM_RASTER_PATH=app/perfis/dem.tif
# Fallback opcional OpenTopography (não necessário no caminho padrão):
# DEM_FONTE=opentopography
# OPENTOPOGRAPHY_API_KEY=sua_chave
# Opcional — limiares (%) das faixas suave/média (default 8 e 20). A vedação legal é 30%.
# DECLIVIDADE_LIMIAR_SUAVE=8
# DECLIVIDADE_LIMIAR_MEDIA=20

# Fase 9/11 — IA do gerador de PROGRAMA urbanístico (a IA propõe a ESTRATÉGIA; o número é do
# motor). É OPCIONAL: sem credencial, o estudo usa o PRESET determinístico (degradação honesta).
# Cadeia de fallback: Claude → Gemini → preset (o 1º que responder vence).
# 1) Claude (provedor primário) — ligue com a chave da Anthropic:
# ANTHROPIC_API_KEY=sua_chave_anthropic
# 2) Gemini (provedor de FALLBACK p/ sobrecarga 529 / apagão da Anthropic) — ligue com a do Google:
# GOOGLE_API_KEY=sua_chave_google
# Modelo do Gemini (default gemini-3.5-flash) — ajuste aqui o ID exato da API SEM tocar no código:
# URBANISMO_GEMINI_MODELO=gemini-3.5-flash
# Nível de "thinking" do Gemini: low | medium | high | <nº de tokens> (default medium):
# URBANISMO_GEMINI_THINKING=medium
# Outros ajustes (opcionais): fixar um modelo Claude, preferir Fable 5, ou DESLIGAR a IA de vez:
# URBANISMO_MODELO=claude-opus-4-8
# IA_PREFERIR_FABLE5=1
# URBANISMO_GERADOR_DESLIGADO=1

# Fase 12 — banco multi-tenant + autenticação.
# Dev local: SQLite num arquivo (default abaixo, gitignored). Produção (Compose): Postgres.
DATABASE_URL=sqlite:///./dev.db
# Produção: DATABASE_URL=postgresql+psycopg://viabilidade:SENHA@db:5432/viabilidade
# Segredos JWT — OBRIGATÓRIO trocar por valores aleatórios. Diferencie os dois.
# Gere com:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
# TTLs (opcionais): access em minutos, refresh em dias.
# JWT_ACCESS_TTL_MIN=30
# JWT_REFRESH_TTL_DIAS=7
# Em produção sob HTTPS, ligue para o cookie de refresh viajar só por TLS:
# COOKIE_SECURE=1
#
# PRODUÇÃO (ver docs/migracao-lightsail.md): defina ENV=production — o boot ABORTA se
# JWT_SECRET/JWT_REFRESH_SECRET/POSTGRES_PASSWORD estiverem ausentes ou no default, se
# CORS_ORIGINS for '*' ou se COOKIE_SECURE != 1.
# ENV=production
# POSTGRES_PASSWORD=CHANGE_ME      # senha forte gerada (sem default em produção)
# ALLOWED_HOSTS=app.seudominio.com.br
